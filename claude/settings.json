      "Bash(tail:*)",
      "Bash(cat:*)",
      "Bash(bat:*)",
      "Bash(diff:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(echo:*)",
      "Bash(fd:*)",
      "Bash(tree:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(ps:*)",
      "Bash(uname:*)",
      "Bash(sw_vers)",

      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(which:*)",
      "Bash(env:*)",
      "Bash(printenv:*)",
      "Bash(tsc:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)",
      "Bash(ktlint:*)",
      "Bash(jest:*)",
      "Bash(vitest:*)",
      "Bash(cargo build)",
      "Bash(cargo test)",
      "Bash(cargo check)",
      "Bash(cargo clippy)",
      "Bash(cargo fmt)",
      "Bash(brew list)",
      "Bash(brew info)",
      "Bash(brew outdated)",
      "Bash(brew search)",
      "Bash(brew deps)",
      "Bash(gradlew)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(pnpm)",

      "WebFetch(domain:github.com)",
      "WebSearch",
      "Bash(coderabbit review:*)"
    ],
    "deny": [],
    "defaultMode": "acceptEdits"
  },
  "statusLine": {
    "type": "command",
    "command": "pnpx ccusage@latest statusline",
    "padding": 0
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754269096080
  },
  "ignorePatterns": [
    ".gradle/",
    "node_modules/",
    "build/",
    "target/",
    "out/",
    "*.jar",
    "*.war",
    "*.ear",
    ".idea/",
    "*.iml",
    "*.log",
    "coverage/"
  ],
  "enabledPlugins": {
    "mapo-aidd@bill-one-marketplace": true
  },
  "enableAllProjectMcpServers": false
}
