      "Edit",

      "Bash(git status)",
      "Bash(git log)",
      "Bash(git diff)",
      "Bash(git show)",
      "Bash(git blame)",
      "Bash(git describe)",
      "Bash(git rev-parse)",
      "Bash(git ls-files)",
      "Bash(git ls-tree)",
      "Bash(git shortlog)",
      "Bash(git reflog)",
      "Bash(git grep)",
      "Bash(git for-each-ref)",
      "Bash(git cat-file)",
      "Bash(git check-ignore)",
      "Bash(git branch)",
      "Bash(git tag)",
      "Bash(git remote)",
      "Bash(git stash list)",
      "Bash(git worktree list)",
      "Bash(git submodule status)",
      "Bash(git config)",

