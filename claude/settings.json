{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Bash(*)",
      "WebFetch",
      "WebSearch",
      "mcp__notion__*",
      "mcp__obsidian-mcp-tools__*",
      "mcp__serena__*",
      "mcp__chrome-devtools__take_screenshot",
      "mcp__chrome-devtools__take_snapshot",
      "mcp__chrome-devtools__list_pages",
      "mcp__chrome-devtools__select_page",
      "mcp__chrome-devtools__get_console_message",
      "mcp__chrome-devtools__list_console_messages",
      "mcp__chrome-devtools__list_network_requests",
      "mcp__chrome-devtools__get_network_request",
      "mcp__chrome-devtools__resize_page",
      "mcp__chrome-devtools__wait_for",
      "mcp__chrome-devtools__close_page",
      "mcp__chrome-devtools__navigate_page"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(git config --global *)",
      "Bash(git config --system *)",
      "Bash(gh api --method DELETE *)",
      "Bash(gh api --method=DELETE *)",
      "Bash(gh api -X DELETE *)",
      "Bash(find * -exec *)",
      "Bash(find * -delete)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/)",
      "Bash(rm -rf $HOME)",
      "Bash(rm -rf $HOME/)"
    ],
    "ask": [
      "Bash(mv *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(kill *)",
      "Bash(pkill *)",
      "Bash(killall *)",
      "Bash(rm -rf *)",
      "Bash(brew uninstall *)",
      "Bash(brew remove *)",
      "Bash(npm uninstall *)",
      "Bash(pnpm uninstall *)",
      "Bash(pnpm remove *)",
      "Bash(pip uninstall *)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git rebase*)",
      "Bash(git reset --hard*)",
      "Bash(git clean*)",
      "Bash(git checkout -- *)",
      "Bash(git restore*)",
      "Bash(git branch -D *)",
      "Bash(gh pr create*)",
      "Bash(gh pr merge*)",
      "Bash(gh pr close*)",
      "Bash(gh pr edit*)",
      "Bash(gh issue create*)",
      "Bash(gh issue close*)",
      "Bash(gh issue edit*)",
      "Bash(gh api --method POST *)",
      "Bash(gh api --method PATCH *)",
      "Bash(gh api --method PUT *)",
      "Bash(gh api --method=POST *)",
      "Bash(gh api --method=PATCH *)",
      "Bash(gh api --method=PUT *)",
      "Bash(gh api -X POST *)",
      "Bash(gh api -X PATCH *)",
      "Bash(gh api -X PUT *)",
      "Bash(sed -i *)",
      "Bash(yq -i *)",
      "Bash(pip install *)",
      "Bash(npm install -g *)",
      "Bash(pnpm add -g *)",
      "Bash(pnpm install -g *)",
      "Bash(brew install *)",
      "mcp__chrome-devtools__evaluate_script",
      "mcp__chrome-devtools__click",
      "mcp__chrome-devtools__drag",
      "mcp__chrome-devtools__fill",
      "mcp__chrome-devtools__fill_form",
      "mcp__chrome-devtools__type_text",
      "mcp__chrome-devtools__press_key",
      "mcp__chrome-devtools__hover",
      "mcp__chrome-devtools__new_page",
      "mcp__chrome-devtools__upload_file",
      "mcp__chrome-devtools__handle_dialog"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "opus[1m]",
  "enableAllProjectMcpServers": false,
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "mapo-aidd@bill-one-marketplace": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "mapo-tools@bill-one-marketplace": true,
    "kotlin-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "mapo-implementation-rules@bill-one-marketplace": true,
    "commit-commands@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "serena@claude-plugins-official": false,
    "mapo-git@bill-one-marketplace": true,
    "superpowers@superpowers-marketplace": true,
    "skill-creator@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-daltonized",
  "feedbackSurveyState": {
    "lastShownTime": 1754269096080
  },
  "ignorePatterns": [
    ".gradle/",
    "node_modules/",
    "build/",
    "target/",
    "out/",
    "*.jar",
    "*.war",
    "*.ear",
    ".idea/",
    "*.iml",
    "*.log",
    "coverage/"
  ]
}
