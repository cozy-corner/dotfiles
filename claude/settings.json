{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Edit",

      "Bash(gradlew)",
      "Bash(pnpm)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "pnpx ccusage@latest statusline",
    "padding": 0
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754269096080
  },
  "ignorePatterns": [
    ".gradle/",
    "node_modules/",
    "build/",
    "target/",
    "out/",
    "*.jar",
    "*.war",
    "*.ear",
    ".idea/",
    "*.iml",
    "*.log",
    "coverage/"
  ],
  "enabledPlugins": {
    "mapo-aidd@bill-one-marketplace": true
  }
}
